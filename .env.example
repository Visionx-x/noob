# GrowthForge API – copy to .env and fill values
# VPS/production: set ENVIRONMENT=production and a strong SECRET_KEY

ENVIRONMENT=development
HOST=0.0.0.0
PORT=2000

DATABASE_URL=sqlite:///./growthforge.db

# Production: use a long random secret (e.g. openssl rand -hex 32)
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30

# CORS: comma-separated. Include capacitor://localhost for mobile app.
# Production: add your API domain, e.g. https://api.yourdomain.com
ALLOWED_ORIGINS=capacitor://localhost,http://localhost,http://127.0.0.1:3000

# Production only (optional): comma-separated hosts for Host header, e.g. api.yourdomain.com
# ALLOWED_HOSTS=api.yourdomain.com

LOG_LEVEL=INFO
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=3600

# Mobile app settings
MOBILE_APP_NAME=GrowthForge
MOBILE_APP_ID=com.growthforge.app

# API URLs for mobile app (update these for production)
MOBILE_API_URL=http://localhost:2000/api
WEB_API_URL=http://localhost:2000/api
